---
import Layout from "./Layout.astro";
import Nav from "../components/nav.astro";
import Contact from "../components/contact.astro";

const { frontmatter } = Astro.props;
---

<Layout title={frontmatter.title || "About | Spandan Hota"}>
	<Nav />
	
	<section class="pt-32 pb-20 px-4 md:px-0">
		<div class="container mx-auto max-w-3xl">
			<div class="mb-12">
				<h1 class="text-4xl md:text-5xl font-heading font-bold text-white mb-4">
					<span class="text-accent">/</span> {frontmatter.title || "About Me"}
				</h1>
				{frontmatter.description && (
					<p class="text-gray-400 font-body text-lg italic">
						{frontmatter.description}
					</p>
				)}
			</div>

			<div class="prose prose-invert prose-accent max-w-none font-body text-gray-300 leading-relaxed">
				<slot />
			</div>
		</div>
	</section>

	<Contact />
</Layout>

<style is:global>
	@reference "../styles/global.css";

	/* Custom Markdown Styling */
	.prose h2 {
		@apply text-2xl font-heading font-bold text-white mt-12 mb-6 flex items-center gap-3;
	}

	.prose h2::before {
		content: "";
		@apply w-1 h-6 bg-accent rounded-full;
	}
	.prose h3 {
		@apply text-xl font-heading font-semibold text-white mt-8 mb-4;
	}
	.prose p {
		@apply mb-6;
	}
	.prose img {
		@apply max-w-full h-auto;
	}
	.prose .about-media {
		@apply mb-6 overflow-hidden rounded-2xl border border-white/15 bg-white/5;
	}
	.prose .about-lfc-image {
		@apply block w-full aspect-[16/9] object-cover;
	}
	.prose .about-icon-row {
		@apply mb-6 flex flex-wrap items-center gap-3;
	}
	.prose .about-icon-row a {
		@apply inline-flex flex-wrap items-center gap-3 no-underline;
	}
	.prose .about-icon-row img {
		@apply m-0 rounded-xl border border-white/12 bg-slate-900/35 p-2 shadow-[0_8px_20px_rgba(0,0,0,0.22)];
	}
	.prose .about-tool-chips {
		@apply mb-6 flex flex-wrap items-center gap-3;
	}
	.prose .about-tool-chip {
		@apply inline-flex items-center gap-2 rounded-full border border-white/12 bg-white/5 px-3 py-1.5 text-sm font-medium text-gray-200;
	}
	.prose .about-tool-chip img {
		@apply m-0 h-5 w-5 rounded-md;
	}
	.prose .about-inline-icon {
		@apply inline-block h-5 w-5 align-middle mr-2 rounded-sm;
	}
	.prose ul {
		@apply list-disc list-inside mb-6 space-y-2;
	}
	.prose li {
		@apply text-gray-300;
	}
	.prose strong {
		@apply text-white font-semibold;
	}
	.prose a {
		@apply text-accent hover:underline transition-all;
	}
	.prose blockquote {
		@apply border-l-4 border-accent pl-6 py-2 italic bg-white/5 rounded-r-lg mb-8;
	}
</style>
