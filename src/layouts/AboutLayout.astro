---
import Layout from "./Layout.astro";
import Nav from "../components/nav.astro";
import Contact from "../components/contact.astro";

const { frontmatter } = Astro.props;
---

<Layout title={frontmatter.title || "About | Spandan Hota"}>
	<Nav />
	
	<section class="pt-32 pb-20 px-4 md:px-0">
		<div class="container mx-auto max-w-3xl">
			<div class="mb-12">
				<h1 class="text-4xl md:text-5xl font-heading font-bold text-white mb-4">
					<span class="text-accent">/</span> {frontmatter.title || "About Me"}
				</h1>
				{frontmatter.description && (
					<p class="text-gray-400 font-body text-lg italic">
						{frontmatter.description}
					</p>
				)}
			</div>

			<div class="prose prose-invert prose-accent max-w-none font-body text-gray-300 leading-relaxed">
				<slot />
			</div>
		</div>
	</section>

	<Contact />
</Layout>

<style is:global>
	@reference "../styles/global.css";

	/* Custom Markdown Styling */
	.prose h2 {
		@apply text-2xl font-heading font-bold text-white mt-12 mb-6 flex items-center gap-3;
	}

	.prose h2::before {
		content: "";
		@apply w-1 h-6 bg-accent rounded-full;
	}
	.prose h3 {
		@apply text-xl font-heading font-semibold text-white mt-8 mb-4;
	}
	.prose p {
		@apply mb-6;
	}
	.prose ul {
		@apply list-disc list-inside mb-6 space-y-2;
	}
	.prose li {
		@apply text-gray-300;
	}
	.prose strong {
		@apply text-white font-semibold;
	}
	.prose a {
		@apply text-accent hover:underline transition-all;
	}
	.prose blockquote {
		@apply border-l-4 border-accent pl-6 py-2 italic bg-white/5 rounded-r-lg mb-8;
	}
</style>
